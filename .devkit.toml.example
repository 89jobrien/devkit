[project]
name         = "my-project"
description  = "A brief description of your project"
install_date = "2026-01-01"
ci_platforms = ["github"]   # "github" | "gitea"

[components]
council  = true   # multi-role branch analysis
review   = true   # AI diff review
meta     = true   # parallel agent task runner
ci_agent = true   # CI failure diagnosis
diagnose = true   # local service log diagnosis

[review]
focus = ""   # optional: focus area for review (e.g. "security", "performance")

[council]
mode = "core"   # "core" (3 roles) | "extensive" (5 roles)

[diagnose]
# log_cmd = "journalctl -n 200 --no-pager"   # shell command to fetch logs
# service = ""                                # focus on a specific service/component

[providers]
# primary             = "anthropic"   # anthropic | openai | gemini — first in fallback chain
# fast_model          = ""            # override model for fast tier (haiku/gpt-5.4-mini/gemini-flash)
# balanced_model      = ""            # override model for balanced tier
# large_context_model = ""            # override model for large-context tier
# coding_model        = ""            # override model for coding tier (no Gemini)
